DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Auth.js (next-auth v4)
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full URL of the deployed app (used for magic link callback URLs)
NEXTAUTH_URL=https://your-domain.com

# Email for magic links. Leave AUTH_EMAIL_SERVER unset in development —
# links log to the server console instead of sending email.
# In production, set both to send real email via any SMTP provider.
AUTH_EMAIL_SERVER=smtp://USER:PASSWORD@HOST:PORT
AUTH_EMAIL_FROM=noreply@your-domain.com
