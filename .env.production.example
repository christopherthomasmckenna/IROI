# Production configuration — copy to .env.production on the server, next to
# docker-compose.prod.yml, and fill in every value. Compose refuses to start
# with any of these missing.

# Postgres password for the containerized database (generate: openssl rand -hex 24)
POSTGRES_PASSWORD=

# Public URL of the site (no trailing slash) — also used in magic-link emails
NEXTAUTH_URL=https://rjcimpact.org

# Session/token secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=

# SMTP URL for magic-link email. Brevo:
#   smtp://BREVO_LOGIN_EMAIL:SMTP_KEY@smtp-relay.brevo.com:2525
# (URL-encode any special characters in the key)
AUTH_EMAIL_SERVER=

# From address on magic-link emails — must be on the Brevo-verified domain
AUTH_EMAIL_FROM=noreply@rjcimpact.org

# Domain Caddy serves + provisions TLS for (DNS must point at this box)
SITE_ADDRESS=rjcimpact.org
